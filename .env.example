# Environment Configuration
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# Database Configuration
DB_HOST=localhost
DB_NAME=gym_management
DB_USERNAME=root
DB_PASSWORD=
ONLINE_DB_HOST=localhost
ONLINE_DB_NAME=gym_management
ONLINE_DB_USERNAME=root
ONLINE_DB_PASSWORD=

# Application Configuration
APP_ENV=development
# Options: development | staging | production
APP_DEBUG=true
# Set to false in production
APP_TIMEZONE=Asia/Karachi

# Security Configuration
SESSION_LIFETIME=3600
# Session lifetime in seconds (default: 1 hour)
CSRF_TOKEN_LIFETIME=3600
# CSRF token lifetime in seconds (default: 1 hour)
SESSION_SECURE_COOKIE=false
# Set to true in production (requires HTTPS)
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# Rate Limiting
RATE_LIMIT_LOGIN_MAX=5
# Maximum login attempts
RATE_LIMIT_LOGIN_WINDOW=900
# Time window in seconds (default: 15 minutes)
RATE_LIMIT_GATE_MAX=10
# Maximum gate requests per window
RATE_LIMIT_GATE_WINDOW=60
# Gate rate limit window in seconds (default: 1 minute)

# Gate Configuration
GATE_ENTRY_COOLDOWN_SECONDS=5
# Cooldown between entry scans for same RFID
GATE_EXIT_COOLDOWN_SECONDS=5
# Cooldown between exit scans for same RFID
GATE_OPEN_DURATION_MS=3000
# Gate motor activation duration in milliseconds
GATE_FORCE_OPEN_DURATION=30
# Force-open duration in seconds

# ESP32 Configuration
ESP32_TIMEOUT_SECONDS=10
# API timeout for ESP32 requests
ESP32_VERIFY_SSL=false
# SSL verification for ESP32 (set true in production with valid cert)

# Logging Configuration
LOG_LEVEL=info
# Options: debug | info | warning | error
LOG_RETENTION_DAYS=90
# Number of days to retain logs
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/error.log
LOG_ADMIN_FILE=logs/admin.log
LOG_MAX_SIZE_MB=10
# Maximum log file size before rotation

# Cache Configuration
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
# Default cache TTL in seconds (5 minutes)
CACHE_DASHBOARD_TTL=300
# Dashboard cache TTL

# Admin Override Configuration
ADMIN_OVERRIDE_LOG=true
# Log all admin override actions
ADMIN_OVERRIDE_REASON_MIN_LENGTH=10
# Minimum characters required for override reason

# Cleanup Jobs Configuration
CLEANUP_ORPHANED_SESSIONS_ENABLED=true
# Auto-close sessions without check-out
CLEANUP_ORPHANED_SESSIONS_HOURS=24
# Close sessions older than X hours without check-out
CLEANUP_OLD_LOGS_ENABLED=true
# Enable automatic log cleanup

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
# Enable /api/health.php endpoint

# Maintenance Mode
MAINTENANCE_MODE=false
# Set to true to enable maintenance mode
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.

# Sync Configuration
ONLINE_SERVER_URL=https://your-online-server.example.com
# Base URL of the online sync target (no trailing slash required)
SYNC_API_KEY=replace_with_a_long_random_secret
# Must match on both local and online environments
